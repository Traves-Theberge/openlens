#!/usr/bin/env bash
# openlens pre-push hook
# Runs a full review on branch diff before push. Blocks push if critical issues found.
# Install: cp hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
# Or: openlens hooks install

set -e

# Skip if OPENLENS_SKIP is set
if [ -n "$OPENLENS_SKIP" ]; then
  exit 0
fi

# Check if openlens is available
if ! command -v openlens &> /dev/null; then
  echo "openlens not found — skipping review"
  exit 0
fi

# Determine base branch (default: main)
BASE_BRANCH="${OPENLENS_BASE_BRANCH:-main}"

# Check if there are commits to push
if git diff --quiet "$BASE_BRANCH"...HEAD 2>/dev/null; then
  exit 0
fi

echo ""
echo "  openlens  reviewing branch diff against $BASE_BRANCH..."
echo ""

# Run review — override agents with OPENLENS_AGENTS env var
# e.g., OPENLENS_AGENTS=security,bugs git push (empty = all agents)
AGENTS="${OPENLENS_AGENTS:-}"
if [ -n "$AGENTS" ]; then
  openlens run --branch "$BASE_BRANCH" --agents "$AGENTS" --format text
else
  openlens run --branch "$BASE_BRANCH" --format text
fi

# Exit code 1 = critical issues found → block push
# Exit code 0 = clean or only warnings → allow push
