{
  "hooks": {
    "AfterTool": [
      {
        "matcher": "write_file|edit_file|replace_in_file",
        "hooks": [
          {
            "type": "command",
            "command": "openlens run --staged --agents security,bugs --no-verify --no-context --format json 2>/dev/null"
          }
        ]
      }
    ]
  }
}
